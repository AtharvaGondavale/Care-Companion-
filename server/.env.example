# PostgreSQL used by Docker Compose (postgres service)
DATABASE_URL=postgresql://care:care@postgres:5432/care_companion?schema=public

PORT=3000

# openssl rand -base64 32
JWT_SECRET=change-me-use-long-random-secret

# Twilio SMS (omit or set TWILIO_MOCK=true for local/dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MOCK=false
